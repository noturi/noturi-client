{
  "cli": {
    "version": ">= 16.17.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal"
    },
    "preview": {
      "distribution": "internal"
    },
    "production": {
      "autoIncrement": true,
      "ios": {
        "appExtensions": [
          {
            "targetName": "NoturiWidget",
            "bundleIdentifier": "com.noturi.app.widget"
          }
        ]
      }
    }
  },
  "submit": {
    "production": {}
  }
}
